<!DOCTYPE html>
<html lang="ru" class="h-full bg-slate-900">
<head>
    <meta charset="UTF-8">
    <title>Вход в Админ-панель ПВТ КР</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="h-full flex items-center justify-center px-4 sm:px-6 lg:px-8">
<div class="max-w-md w-full space-y-8 bg-slate-800 p-8 rounded-2xl shadow-xl border border-slate-700">
    <div>
        <h2 class="mt-2 text-center text-3xl font-extrabold text-white">Админ-панель</h2>
        <p class="mt-2 text-center text-sm text-slate-400">ИИ-ассистент Дирекции ПВТ КР</p>
    </div>
    <form class="mt-8 space-y-6" action="/admin/login" method="POST">
        <div class="rounded-md shadow-sm -space-y-px">
            <div>
                <label for="password" class="sr-only">Пароль администратора</label>
                <input id="password" name="password" type="password" required class="appearance-none rounded-lg relative block w-full px-4 py-3 border border-slate-600 placeholder-slate-400 text-white bg-slate-700 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 focus:z-10 sm:text-sm" placeholder="Введите пароль администратора">
            </div>
        </div>

        <% if (error) { %>
            <div class="bg-red-900/50 border border-red-500 text-red-200 px-4 py-3 rounded-lg text-sm" role="alert">
                <%= error %>
            </div>
        <% } %>

        <div>
            <button type="submit" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors">
                Войти в панель
            </button>
        </div>
    </form>
</div>
</body>
</html>