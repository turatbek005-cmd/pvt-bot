<!DOCTYPE html>
<html lang="ru" class="h-full bg-slate-900">
<head>
    <meta charset="UTF-8">
    <title>Вход в Админ-панель ПВТ КР</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      // Включаем поддержку темного режима по классу
      tailwind.config = { darkMode: 'class' }

      // Автоматически считываем и применяем сохраненную тему админа при загрузке страницы
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
</head>
<body class="h-full flex items-center justify-center px-4 sm:px-6 lg:px-8 transition-colors duration-200 bg-slate-50 dark:bg-slate-900 text-slate-900 dark:text-slate-100">
<div class="max-w-md w-full space-y-8 bg-white dark:bg-slate-800 p-8 rounded-2xl shadow-xl border border-slate-200 dark:border-slate-700">
    <div class="flex flex-col items-center">
        <!-- Иконка замка -->
        <span class="text-4xl p-3 bg-indigo-500/10 text-indigo-500 rounded-2xl mb-4">🔐</span>
        <h2 class="text-center text-3xl font-extrabold">Админ-панель</h2>
        <p class="mt-2 text-center text-sm text-slate-500 dark:text-slate-400">ИИ-ассистент Дирекции ПВТ КР</p>
    </div>

    <form class="mt-8 space-y-6" action="/admin/login" method="POST">
        <div class="rounded-md shadow-sm">
            <div>
                <label for="password" class="block text-sm font-medium text-slate-500 dark:text-slate-400 mb-2">Пароль администратора:</label>
                <input id="password" name="password" type="password" required class="appearance-none rounded-lg relative block w-full px-4 py-3 border border-slate-350 dark:border-slate-600 placeholder-slate-500 text-slate-900 dark:text-white bg-slate-100 dark:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="Введите пароль администратора">
            </div>
        </div>

        <% if (error) { %>
            <div class="bg-red-500/10 border border-red-500 text-red-500 px-4 py-3 rounded-lg text-sm" role="alert">
                ⚠️ <%= error %>
            </div>
        <% } %>

        <div>
            <button type="submit" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-semibold rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors shadow-md">
                Войти в панель
            </button>
        </div>
    </form>
</div>
</body>
</html>