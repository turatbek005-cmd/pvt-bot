<!DOCTYPE html>
<html lang="ru" class="h-full">
<head>
    <meta charset="UTF-8">
    <title>Статистика | Админка ПВТ КР</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = { darkMode: 'class' }
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
</head>
<body class="h-full flex transition-colors duration-200 bg-slate-50 text-slate-900 dark:bg-slate-900 dark:text-slate-100">

<!-- САЙДБАР НАВИГАЦИИ -->
<div class="w-64 bg-slate-100 dark:bg-slate-800 border-r border-slate-200 dark:border-slate-700 flex flex-col justify-between">
    <div class="p-6">
        <h2 class="text-xl font-bold tracking-wider text-slate-800 dark:text-white">ПВТ КР Админ</h2>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Панель управления ИИ</p>

        <!-- Кнопка переключения темы -->
        <button onclick="toggleTheme()" class="mt-4 w-full flex items-center justify-center gap-2 px-4 py-2 bg-slate-200 dark:bg-slate-700 text-sm font-semibold rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors">
            🌓 Сменить тему
        </button>

        <nav class="mt-8 space-y-2">
            <a href="/admin" class="flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-colors bg-indigo-600 text-white">
                📊 Статистика
            </a>
            <a href="/admin/users" class="flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-colors text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700">
                👥 Пользователи
            </a>
            <a href="/admin/logs" class="flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-colors text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700">
                💬 Логи переписок
            </a>
            <a href="/admin/documents" class="flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-colors text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700">
                📚 База знаний
            </a>
        </nav>
    </div>
    <div class="p-6 border-t border-slate-200 dark:border-slate-700">
        <a href="/admin/logout" class="flex items-center justify-center w-full px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-medium rounded-lg transition-colors">
            🚪 Выйти
        </a>
    </div>
</div>

<!-- ОСНОВНОЙ КОНТЕНТ -->
<div class="flex-1 p-10 overflow-y-auto">
    <div class="flex justify-between items-center mb-10">
        <h1 class="text-3xl font-extrabold">📊 Общая статистика</h1>
        <p class="text-sm text-slate-500 dark:text-slate-400">Сегодня: <%= new Date().toLocaleDateString('ru-RU') %></p>
    </div>

    <!-- КЛИКАБЕЛЬНЫЕ КАРТОЧКИ СТАТИСТИКИ -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <!-- Карточка 1: Пользователи (ведет на список пользователей) -->
        <a href="/admin/users" class="bg-slate-100 dark:bg-slate-800 p-6 rounded-2xl border border-slate-200 dark:border-slate-700 flex items-center justify-between hover:scale-[1.02] hover:shadow-lg transition-all duration-200">
            <div>
                <p class="text-sm text-slate-500 dark:text-slate-400 font-medium">Всего пользователей</p>
                <p class="text-3xl font-bold mt-2"><%= stats.totalUsers %></p>
                <span class="text-xs text-indigo-500 font-semibold mt-1 block">🔍 Посмотреть список →</span>
            </div>
            <div class="p-4 bg-indigo-500/10 text-indigo-500 rounded-xl text-2xl">👥</div>
        </a>

        <!-- Карточка 2: Сообщения (ведет на все логи) -->
        <a href="/admin/logs" class="bg-slate-100 dark:bg-slate-800 p-6 rounded-2xl border border-slate-200 dark:border-slate-700 flex items-center justify-between hover:scale-[1.02] hover:shadow-lg transition-all duration-200">
            <div>
                <p class="text-sm text-slate-500 dark:text-slate-400 font-medium">Всего сообщений</p>
                <p class="text-3xl font-bold mt-2"><%= stats.totalMessages %></p>
                <span class="text-xs text-emerald-500 font-semibold mt-1 block">🔍 Открыть логи →</span>
            </div>
            <div class="p-4 bg-emerald-500/10 text-emerald-500 rounded-xl text-2xl">💬</div>
        </a>

        <!-- Карточка 3: Неотвеченные вопросы (ведет на логи с авто-фильтром) -->
        <a href="/admin/logs?filter=unhandled" class="bg-slate-100 dark:bg-slate-800 p-6 rounded-2xl border border-slate-200 dark:border-slate-700 flex items-center justify-between hover:scale-[1.02] hover:shadow-lg transition-all duration-200">
            <div>
                <p class="text-sm text-slate-500 dark:text-slate-400 font-medium">Вопросы без ответа (ошибки)</p>
                <p class="text-3xl font-bold text-red-500 mt-2"><%= stats.unhandledCount %></p>
                <span class="text-xs text-red-500 font-semibold mt-1 block">🔍 Изучить ошибки →</span>
            </div>
            <div class="p-4 bg-red-500/10 text-red-500 rounded-xl text-2xl">⚠️</div>
        </a>
    </div>

    <div class="p-6 bg-slate-200/50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 rounded-2xl">
        <h3 class="text-lg font-bold mb-2">Добро пожаловать в админ-панель!</h3>
        <p class="text-slate-500 dark:text-slate-400 leading-relaxed text-sm">
            Эта панель позволяет Дирекции ПВТ КР контролировать качество ответов искусственного интеллекта. Карточки выше теперь кликабельны: кликните на любую метрику, чтобы мгновенно перейти к детальным спискам или отфильтровать ошибки ИИ.
        </p>
    </div>
</div>

<script>
  function toggleTheme() {
    if (document.documentElement.classList.contains('dark')) {
      document.documentElement.classList.remove('dark');
      localStorage.theme = 'light';
    } else {
      document.documentElement.classList.add('dark');
      localStorage.theme = 'dark';
    }
  }
</script>
</body>
</html>