<!DOCTYPE html>
<html lang="ru" class="h-full">
<head>
    <meta charset="UTF-8">
    <title>База знаний | Админка ПВТ КР</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = { darkMode: 'class' }
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
</head>
<body class="h-full text-slate-100 flex transition-colors duration-200 bg-slate-50 text-slate-900 dark:bg-slate-900 dark:text-slate-100">

<!-- САЙДБАР НАВИГАЦИИ -->
<div class="w-64 bg-slate-100 dark:bg-slate-800 border-r border-slate-200 dark:border-slate-700 flex flex-col justify-between">
    <div class="p-6">
        <h2 class="text-xl font-bold tracking-wider text-slate-800 dark:text-white">ПВТ КР Админ</h2>
        <p class="text-xs text-slate-400 mt-1">Панель управления ИИ</p>
        <button onclick="toggleTheme()" class="mt-4 w-full flex items-center justify-center gap-2 px-4 py-2 bg-slate-200 dark:bg-slate-700 text-sm font-semibold rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors">
            🌓 Сменить тему
        </button>
        <nav class="mt-8 space-y-2">
            <a href="/admin" class="flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-colors text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700">
                📊 Статистика
            </a>
            <a href="/admin/users" class="flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-colors text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700">
                👥 Пользователи
            </a>
            <a href="/admin/logs" class="flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-colors text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700">
                💬 Логи переписок
            </a>
            <a href="/admin/documents" class="flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-colors bg-indigo-600 text-white">
                📚 База знаний
            </a>
        </nav>
    </div>
    <div class="p-6 border-t border-slate-200 dark:border-slate-700">
        <a href="/admin/logout" class="flex items-center justify-center w-full px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-medium rounded-lg transition-colors">
            🚪 Выйти
        </a>
    </div>
</div>

<!-- ОСНОВНОЙ КОНТЕНТ -->
<div class="flex-1 p-10 overflow-y-auto">
    <div class="flex justify-between items-center mb-10">
        <h1 class="text-3xl font-extrabold text-slate-800 dark:text-white">📚 Менеджер Базы знаний</h1>
        <p class="text-sm text-slate-500 dark:text-slate-400">Загружено документов: <%= docs.length %></p>
    </div>

    <!-- ФОРМА ДОБАВЛЕНИЯ -->
    <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl p-6 mb-10 shadow-md">
        <h2 class="text-xl font-bold mb-4">📥 Загрузить и векторизовать новый документ</h2>
        <form action="/admin/documents" method="POST" class="space-y-4">
            <div>
                <label for="source" class="block text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Источник (Название статьи/положения):</label>
                <input type="text" id="source" name="source" required placeholder="Например: Статья 6. Порядок выхода из ПВТ КР" class="w-full px-4 py-2.5 rounded-lg border border-slate-200 dark:border-slate-600 placeholder-slate-500 bg-slate-100 dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
            </div>
            <div>
                <label for="content" class="block text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Текст статьи (закона/постановления):</label>
                <textarea id="content" name="content" rows="5" required placeholder="Вставьте сюда точный текст статьи, которую должен запомнить ИИ..." class="w-full px-4 py-2.5 rounded-lg border border-slate-200 dark:border-slate-600 placeholder-slate-500 bg-slate-100 dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500"></textarea>
            </div>
            <div class="flex justify-end">
                <button type="submit" class="px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors shadow-md">
                    ⚡ Векторизовать и сохранить в ИИ-память
                </button>
            </div>
        </form>
    </div>

    <!-- ТАБЛИЦА ВСЕХ ЗАГРУЖЕННЫХ СТАТЕЙ -->
    <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl overflow-hidden shadow-md">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
                <thead class="bg-slate-100 dark:bg-slate-750">
                <tr>
                    <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Источник</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Дата загрузки</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Превью текста</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Действия</th>
                </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 dark:divide-slate-700 bg-white dark:bg-slate-800">
                <% if (docs.length === 0) { %>
                    <tr>
                        <td colspan="4" class="px-6 py-10 text-center text-sm text-slate-400">В базе знаний пока нет ни одного документа.</td>
                    </tr>
                <% } %>
                <% docs.forEach(function(doc) { %>
                    <tr class="hover:bg-slate-100/30 dark:hover:bg-slate-750/30 transition-colors">
                        <td class="px-6 py-4 text-sm font-bold text-indigo-600 dark:text-indigo-400 max-w-xs truncate">
                            <a href="/admin/documents/<%= doc.id %>/edit" class="hover:underline">
                                <%= doc.source %>
                            </a>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 dark:text-slate-400">
                            <%= new Date(doc.createdAt).toLocaleDateString('ru-RU') %>
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-300 max-w-sm truncate">
                            <%= doc.content %>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium flex gap-3">
                            <a href="/admin/documents/<%= doc.id %>/edit" class="text-indigo-600 dark:text-indigo-400 hover:underline">
                                ✏️ Редактировать
                            </a>
                            <form action="/admin/documents/<%= doc.id %>/delete" method="POST" onsubmit="return confirm('Вы уверены, что хотите навсегда удалить этот документ и его вектор из базы данных?');" class="inline">
                                <button type="submit" class="text-red-500 hover:text-red-700 hover:underline">
                                    🗑️ Удалить
                                </button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
  function toggleTheme() {
    if (document.documentElement.classList.contains('dark')) {
      document.documentElement.classList.remove('dark');
      localStorage.theme = 'light';
    } else {
      document.documentElement.classList.add('dark');
      localStorage.theme = 'dark';
    }
  }
</script>
</body>
</html>