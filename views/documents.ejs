<!DOCTYPE html>
<html lang="ru" class="h-full bg-slate-900">
<head>
    <meta charset="UTF-8">
    <title>База знаний | Админка ПВТ КР</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="h-full text-slate-100 flex">

<!-- САЙДБАР НАВИГАЦИИ -->
<div class="w-64 bg-slate-800 border-r border-slate-700 flex flex-col justify-between">
    <div class="p-6">
        <h2 class="text-xl font-bold text-white tracking-wider">ПВТ КР Админ</h2>
        <p class="text-xs text-slate-400 mt-1">Панель управления ИИ</p>
        <nav class="mt-8 space-y-2">
            <a href="/admin" class="flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-colors hover:bg-slate-700 text-slate-300">
                📊 Статистика
            </a>
            <a href="/admin/logs" class="flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-colors hover:bg-slate-700 text-slate-300">
                💬 Логи переписок
            </a>
            <a href="/admin/documents" class="flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-colors <%= activeTab === 'documents' ? 'bg-indigo-600 text-white' : 'text-slate-300 hover:bg-slate-700' %>">
                📚 База знаний
            </a>
        </nav>
    </div>
    <div class="p-6 border-t border-slate-700">
        <a href="/admin/logout" class="flex items-center justify-center w-full px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-medium rounded-lg transition-colors">
            🚪 Выйти
        </a>
    </div>
</div>

<!-- ОСНОВНОЙ КОНТЕНТ -->
<div class="flex-1 p-10 overflow-y-auto">
    <div class="flex justify-between items-center mb-10">
        <h1 class="text-3xl font-extrabold text-white">📚 Менеджер Базы знаний</h1>
        <p class="text-sm text-slate-400">Статей в ИИ-памяти: <%= docs.length %></p>
    </div>

    <!-- ФОРМА ДОБАВЛЕНИЯ НОВОГО ДОКУМЕНТА -->
    <div class="bg-slate-800 border border-slate-700 rounded-2xl p-6 mb-10 shadow-xl">
        <h2 class="text-xl font-bold text-white mb-4">📥 Загрузить и векторизовать новый документ</h2>
        <form action="/admin/documents" method="POST" class="space-y-4">
            <div>
                <label for="source" class="block text-sm font-medium text-slate-400 mb-1">Источник (Название статьи/положения):</label>
                <input type="text" id="source" name="source" required placeholder="Например: Статья 6. Порядок выхода из ПВТ КР" class="w-full px-4 py-2.5 rounded-lg border border-slate-600 placeholder-slate-500 bg-slate-700 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
            </div>
            <div>
                <label for="content" class="block text-sm font-medium text-slate-400 mb-1">Текст статьи (закона/постановления):</label>
                <textarea id="content" name="content" rows="5" required placeholder="Вставьте сюда точный текст статьи, которую должен запомнить ИИ..." class="w-full px-4 py-2.5 rounded-lg border border-slate-600 placeholder-slate-500 bg-slate-700 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500"></textarea>
            </div>
            <div class="flex justify-end">
                <button type="submit" class="px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors shadow-lg">
                    ⚡ Векторизовать и сохранить в ИИ-память
                </button>
            </div>
        </form>
    </div>

    <!-- ТАБЛИЦА ВСЕХ ЗАГРУЖЕННЫХ СТАТЕЙ -->
    <div class="bg-slate-800 border border-slate-700 rounded-2xl overflow-hidden shadow-xl">
        <div class="p-6 border-b border-slate-700">
            <h2 class="text-xl font-bold text-white">Список загруженных статей закона</h2>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-700">
                <thead class="bg-slate-750">
                <tr>
                    <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Источник</th>
                    <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Дата загрузки</th>
                    <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Превью текста</th>
                </tr>
                </thead>
                <tbody class="divide-y divide-slate-700 bg-slate-800">
                <% if (docs.length === 0) { %>
                    <tr>
                        <td colspan="3" class="px-6 py-10 text-center text-sm text-slate-400">В базе знаний пока нет ни одного документа.</td>
                    </tr>
                <% } %>
                <% docs.forEach(function(doc) { %>
                    <tr class="hover:bg-slate-750/30 transition-colors">
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-indigo-400">
                            <%= doc.source %>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-400">
                            <%= new Date(doc.createdAt).toLocaleDateString('ru-RU') %>
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-300 max-w-md break-words truncate">
                            <%= doc.content.length > 150 ? doc.content.substring(0, 150) + '...' : doc.content %>
                        </td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

</body>
</html>