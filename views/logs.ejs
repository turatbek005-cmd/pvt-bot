<!DOCTYPE html>
<html lang="ru" class="h-full bg-slate-900">
<head>
    <meta charset="UTF-8">
    <title>Логи переписок | Админка ПВТ КР</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="h-full text-slate-100 flex">

<!-- САЙДБАР НАВИГАЦИИ -->
<div class="w-64 bg-slate-800 border-r border-slate-700 flex flex-col justify-between">
    <div class="p-6">
        <h2 class="text-xl font-bold text-white tracking-wider">ПВТ КР Админ</h2>
        <p class="text-xs text-slate-400 mt-1">Панель управления ИИ</p>
        <nav class="mt-8 space-y-2">
            <a href="/admin" class="flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-colors hover:bg-slate-700 text-slate-300">
                📊 Статистика
            </a>
            <a href="/admin/logs" class="flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-colors <%= activeTab === 'logs' ? 'bg-indigo-600 text-white' : 'text-slate-300 hover:bg-slate-700' %>">
                💬 Логи переписок
            </a>
            <a href="/admin/documents" class="flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-colors hover:bg-slate-700 text-slate-300">
                📚 База знаний
            </a>
        </nav>
    </div>
    <div class="p-6 border-t border-slate-700">
        <a href="/admin/logout" class="flex items-center justify-center w-full px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-medium rounded-lg transition-colors">
            🚪 Выйти
        </a>
    </div>
</div>

<!-- ОСНОВНОЙ КОНТЕНТ -->
<div class="flex-1 p-10 overflow-y-auto">
    <div class="flex justify-between items-center mb-10">
        <h1 class="text-3xl font-extrabold text-white">💬 Логи переписок</h1>
        <p class="text-sm text-slate-400">Всего записей: <%= logs.length %></p>
    </div>

    <!-- ТАБЛИЦА ЛОГОВ -->
    <div class="bg-slate-800 border border-slate-700 rounded-2xl overflow-hidden shadow-xl">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-700">
                <thead class="bg-slate-750">
                <tr>
                    <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Время</th>
                    <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Пользователь</th>
                    <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Роль</th>
                    <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Текст сообщения</th>
                </tr>
                </thead>
                <tbody class="divide-y divide-slate-700 bg-slate-800">
                <% if (logs.length === 0) { %>
                    <tr>
                        <td colspan="4" class="px-6 py-10 text-center text-sm text-slate-400">Переписки пока отсутствуют.</td>
                    </tr>
                <% } %>
                <% logs.forEach(function(log) { %>
                    <tr class="hover:bg-slate-750/30 transition-colors">
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-400">
                            <%= new Date(log.createdAt).toLocaleString('ru-RU') %>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-white">
                            <%= log.user.firstName %> <%= log.user.lastName || '' %>
                            <% if (log.user.username) { %>
                                <span class="text-indigo-400 text-xs block mt-0.5">@<%= log.user.username %></span>
                            <% } %>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            <% if (log.role === 'user') { %>
                                <span class="px-2.5 py-1 text-xs font-semibold rounded-full bg-indigo-500/10 text-indigo-400">Пользователь</span>
                            <% } else { %>
                                <span class="px-2.5 py-1 text-xs font-semibold rounded-full bg-emerald-500/10 text-emerald-400">ИИ-Бот</span>
                            <% } %>
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-300 max-w-lg break-words">
                            <%= log.text %>
                        </td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

</body>
</html>