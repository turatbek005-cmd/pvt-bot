<!DOCTYPE html>
<html lang="ru" class="h-full">
<head>
    <meta charset="UTF-8">
    <title>Логи переписок | Админка ПВТ КР</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = { darkMode: 'class' }
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
</head>
<body class="h-full flex transition-colors duration-200 bg-slate-50 text-slate-900 dark:bg-slate-900 dark:text-slate-100">

<!-- САЙДБАР НАВИГАЦИИ -->
<div class="w-64 bg-slate-100 dark:bg-slate-800 border-r border-slate-200 dark:border-slate-700 flex flex-col justify-between">
    <div class="p-6">
        <h2 class="text-xl font-bold tracking-wider text-slate-800 dark:text-white">ПВТ КР Админ</h2>
        <p class="text-xs text-slate-400 mt-1">Панель управления ИИ</p>
        <button onclick="toggleTheme()" class="mt-4 w-full flex items-center justify-center gap-2 px-4 py-2 bg-slate-200 dark:bg-slate-700 text-sm font-semibold rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors">
            🌓 Сменить тему
        </button>
        <nav class="mt-8 space-y-2">
            <a href="/admin" class="flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-colors text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700">
                📊 Статистика
            </a>
            <a href="/admin/users" class="flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-colors text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700">
                👥 Пользователи
            </a>
            <a href="/admin/logs" class="flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-colors bg-indigo-600 text-white">
                💬 Логи переписок
            </a>
            <a href="/admin/documents" class="flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-colors text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700">
                📚 База знаний
            </a>
        </nav>
    </div>
    <div class="p-6 border-t border-slate-200 dark:border-slate-700">
        <a href="/admin/logout" class="flex items-center justify-center w-full px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-medium rounded-lg transition-colors">
            🚪 Выйти
        </a>
    </div>
</div>

<!-- ОСНОВНОЙ КОНТЕНТ -->
<div class="flex-1 p-10 overflow-y-auto">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-extrabold">💬 Логи переписок</h1>
        <p class="text-sm text-slate-500 dark:text-slate-400">Показано записей: <%= logs.length %></p>
    </div>

    <!-- КНОПКИ БЫСТРОЙ ФИЛЬТРАЦИИ -->
    <div class="flex gap-3 mb-8">
        <a href="/admin/logs" class="px-4 py-2 text-xs font-semibold rounded-lg transition-all <%= currentFilter === 'all' ? 'bg-indigo-600 text-white shadow-md' : 'bg-slate-200 text-slate-700 dark:bg-slate-800 dark:text-slate-300 hover:bg-slate-300 dark:hover:bg-slate-700' %>">
            🌐 Все сообщения
        </a>
        <a href="/admin/logs?filter=user" class="px-4 py-2 text-xs font-semibold rounded-lg transition-all <%= currentFilter === 'user' ? 'bg-indigo-600 text-white shadow-md' : 'bg-slate-200 text-slate-700 dark:bg-slate-800 dark:text-slate-300 hover:bg-slate-300 dark:hover:bg-slate-700' %>">
            👥 Вопросы пользователей
        </a>
        <a href="/admin/logs?filter=bot" class="px-4 py-2 text-xs font-semibold rounded-lg transition-all <%= currentFilter === 'bot' ? 'bg-indigo-600 text-white shadow-md' : 'bg-slate-200 text-slate-700 dark:bg-slate-800 dark:text-slate-300 hover:bg-slate-300 dark:hover:bg-slate-700' %>">
            🤖 Ответы ИИ-Бота
        </a>
        <a href="/admin/logs?filter=unhandled" class="px-4 py-2 text-xs font-semibold rounded-lg border border-red-500/30 transition-all <%= currentFilter === 'unhandled' ? 'bg-red-600 text-white shadow-md' : 'bg-red-500/10 text-red-500 hover:bg-red-500/20' %>">
            ⚠️ Вопросы без ответа (Ошибки)
        </a>
    </div>

    <!-- ТАБЛИЦА ЛОГОВ -->
    <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl overflow-hidden shadow-md">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
                <thead class="bg-slate-100 dark:bg-slate-750">
                <tr>
                    <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Время</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Пользователь</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Роль</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Текст сообщения</th>
                </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 dark:divide-slate-700 bg-white dark:bg-slate-800">
                <% if (logs.length === 0) { %>
                    <tr>
                        <td colspan="4" class="px-6 py-10 text-center text-sm text-slate-400">Записи отсутствуют.</td>
                    </tr>
                <% } %>
                <% logs.forEach(function(log) { %>
                    <tr class="hover:bg-slate-100/30 dark:hover:bg-slate-750/30 transition-colors">
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-400">
                            <%= new Date(log.createdAt).toLocaleString('ru-RU') %>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold">
                            <a href="/admin/users/<%= log.user.id %>" class="hover:underline text-indigo-600 dark:text-indigo-400">
                                <%= log.user.firstName %> <%= log.user.lastName || '' %>
                            </a>
                            <% if (log.user.username) { %>
                                <span class="text-slate-400 dark:text-slate-500 text-xs block mt-0.5">@<%= log.user.username %></span>
                            <% } %>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            <% if (log.role === 'user') { %>
                                <span class="px-2.5 py-1 text-xs font-semibold rounded-full bg-indigo-500/10 text-indigo-400">Пользователь</span>
                            <% } else { %>
                                <span class="px-2.5 py-1 text-xs font-semibold rounded-full bg-emerald-500/10 text-emerald-400">ИИ-Бот</span>
                            <% } %>
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-300 max-w-lg break-words leading-relaxed">
                            <%= log.text %>
                        </td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
  function toggleTheme() {
    if (document.documentElement.classList.contains('dark')) {
      document.documentElement.classList.remove('dark');
      localStorage.theme = 'light';
    } else {
      document.documentElement.classList.add('dark');
      localStorage.theme = 'dark';
    }
  }
</script>
</body>
</html>